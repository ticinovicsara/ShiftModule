# ============================================================================
# SHIFT MODULE - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and update values as needed.
# Variables marked [REQUIRED] must be set for the application to work.
# Variables marked [OPTIONAL] have sensible defaults.
# ============================================================================

# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================

# Environment mode: development, staging, production
# [OPTIONAL] Default: development
NODE_ENV=development

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Server port to listen on
# [OPTIONAL] Default: 3000
PORT=3000

# ============================================================================
# AUTHENTICATION - JWT
# ============================================================================

# JWT signing secret for token generation
# [REQUIRED for production] Default: 'secret' (insecure - change in production!)
# For development: minimum 32 characters recommended
# Example: $(openssl rand -base64 32)
JWT_SECRET=prototype-secret-min-32-chars-change-in-prod

# JWT token expiration time
# [OPTIONAL] Default: 7d
# Format: NestJS/node-jsonwebtoken format (e.g., '7d', '24h', '3600')
JWT_EXPIRY=7d

# ============================================================================
# CORS - Cross-Origin Resource Sharing
# ============================================================================

# Comma-separated list of allowed origins for CORS
# [OPTIONAL] Default: http://localhost:5173 (Vite dev server)
# Examples:
#   - Local dev: CORS_ORIGINS=http://localhost:5173,http://localhost:3000
#   - Production: CORS_ORIGINS=https://myapp.edu,https://api.myapp.edu
# WARNING: Never use '*' in production (instead, explicitly list origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# EMAIL NOTIFICATIONS
# ============================================================================

# Email service provider
# [OPTIONAL] Default: console
# Options:
#   - console: Logs emails to console (for development)
#   - smtp: Use SMTP server (requires EMAIL_SMTP_* variables)
#   - sendgrid: Use SendGrid API (requires SENDGRID_API_KEY)
EMAIL_PROVIDER=console

# Default "From" email address for outgoing emails
# [OPTIONAL] Default: noreply@shift.local
# Example: noreply@university.edu
EMAIL_FROM=noreply@shift.local

# ============================================================================
# EMAIL CONFIGURATION - SMTP
# ============================================================================
# Only required when EMAIL_PROVIDER=smtp

# SMTP server hostname
# [OPTIONAL] Required only if EMAIL_PROVIDER=smtp
# Examples: smtp.gmail.com, smtp.outlook.com, mail.company.edu
# EMAIL_SMTP_HOST=smtp.gmail.com

# SMTP server port
# [OPTIONAL] Required only if EMAIL_PROVIDER=smtp
# Common ports: 587 (TLS), 465 (SSL), 25 (unencrypted)
# EMAIL_SMTP_PORT=587

# SMTP username for authentication
# [OPTIONAL] Required only if SMTP server requires auth
# EMAIL_SMTP_USER=your-email@gmail.com

# SMTP password for authentication
# [OPTIONAL] Required only if SMTP server requires auth
# EMAIL_SMTP_PASSWORD=your-app-password

# ============================================================================
# EMAIL CONFIGURATION - SENDGRID
# ============================================================================
# Only required when EMAIL_PROVIDER=sendgrid

# SendGrid API key for email sending
# [OPTIONAL] Required only if EMAIL_PROVIDER=sendgrid
# Get key from: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# ============================================================================
# DATABASE
# ============================================================================
# Only required when implementing database layer (future)

# PostgreSQL connection string
# [OPTIONAL] Not currently used (all data in-memory for development)
# Format: postgresql://user:password@host:port/database
# Example: postgresql://postgres:password@localhost:5432/shift_dev
# DATABASE_URL=postgresql://postgres:password@localhost:5432/shift_dev

# ============================================================================
# MOODLE/MERLIN INTEGRATION
# ============================================================================
# Only required when integrating with Moodle for SSO

# Moodle OAuth authorization URL
# [OPTIONAL] Not used in development (for future Moodle integration)
# Example: https://your-moodle.edu/auth/oauth/token.php
# MOODLE_OAUTH_URL=https://your-moodle.edu/auth/oauth/token.php

# Moodle OAuth client ID
# [OPTIONAL] Not used in development (for future Moodle integration)
# Obtained when registering ShiftModule as OAuth consumer in Moodle
# MOODLE_CLIENT_ID=shift-module-client

# Moodle OAuth client secret
# [OPTIONAL] Not used in development (for future Moodle integration)
# Keep this secret! Obtained when registering OAuth consumer in Moodle
# MOODLE_CLIENT_SECRET=your-secret-key-here

# Moodle API base URL
# [OPTIONAL] Not used in development (for future Moodle integration)
# Example: https://your-moodle.edu/webservice/rest/server.php
# MOODLE_API_URL=https://your-moodle.edu/webservice/rest/server.php

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# Used by Vite during frontend build (apps/client)

# Backend API URL
# [OPTIONAL] Default: http://localhost:3000 (when not set)
# For local development: http://localhost:3000
# For production: https://api.myapp.edu
# Note: This is accessed via import.meta.env.VITE_API_URL in React code
VITE_API_URL=http://localhost:3000

# ============================================================================
# DEVELOPMENT & DEBUGGING
# ============================================================================

# Enable debug logging (future use)
# [OPTIONAL] Default: false
# DEBUG=shift:*

# ============================================================================
# QUICK START INSTRUCTIONS
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your values (only required vars if starting fresh)
# 3. Start backend:
#    cd apps/server
#    pnpm dev
# 4. Start frontend (in separate terminal):
#    cd apps/client
#    pnpm dev
# 5. Open http://localhost:5173 in browser
